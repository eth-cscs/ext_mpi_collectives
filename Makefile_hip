#CC = /capstor/scratch/cscs/ajocksch/install_mpich_todi/bin/mpicc
CC = mpicc
NVCC = hipcc
OBJ = obj
BIN = bin
LIBNAME = ext_mpi_collectives
INCLUDE = -I/user-environment/linux-sles15-neoverse_v2/gcc-13.3.0/cuda-12.6.0-2xobtpf6c4o7h66qrskjdalryoi3gdxf/include -I. -Iinclude/core -Iinclude/mpi -Iinclude/gpu -I/user-environment/linux-sles15-neoverse_v2/gcc-13.2.0/cuda-12.4.0-wezsc3dqlnvhhvjyvi5xrkxe2t2ofwgo/include -I/usr/include -I/opt/cray/xpmem/default/include

DEPDIR := .deps
directories := $(shell (mkdir -p $(DEPDIR); mkdir -p $(DEPDIR)/core; mkdir -p $(DEPDIR)/mpi; mkdir -p $(DEPDIR)/fortran; mkdir -p $(DEPDIR)/initial_benchmark; mkdir -p $(DEPDIR)/noopt; mkdir -p $(DEPDIR)/gpu; mkdir -p $(OBJ); mkdir -p $(OBJ)/core; mkdir -p $(OBJ)/mpi; mkdir -p $(OBJ)/fortran; mkdir -p $(OBJ)/initial_benchmark; mkdir -p $(OBJ)/noopt; mkdir -p $(OBJ)/gpu; mkdir -p $(BIN); mkdir -p lib; mkdir bin_tests))

CFLAGS = -D__HIP_PLATFORM_AMD__ -fPIC -g -O3 -Wall $(INCLUDE) -DM_MAP -DGPU_ENABLED -DXPMEM -DPROFILE
NVCFLAGS = -fPIC -g -O3 $(INCLUDE) -DM_MAP -DGPU_ENABLED -DXPMEM

SOURCES = $(wildcard src/core/*.c src/mpi/*.c src/fortran/*.c src/noopt/*.c src/initial_benchmark/*.c src/gpu/cuda*.c)
OBJECTS = $(subst src,$(OBJ),$(SOURCES:.c=.o))
TESTS = $(wildcard tests/*.c)
TESTSBIN = $(subst tests,bin_tests,$(TESTS:.c=.x))
INITBENCHMARKS = $(wildcard src/initial_benchmark/*.c)
INITBENCHMARKSBIN = $(subst src/initial_benchmark,bin,$(INITBENCHMARKS:.c=.x))
LIBS = -L/user-environment/env/._develop/wq33hmjnmzdfaf7fosrbo7rdoizm2ctm/lib64/stubs -L/user-environment/linux-sles15-neoverse_v2/gcc-12.3.0/cuda-12.2.1-xm4nc7qdi5czjv7thmcfqhki6e6x3q2n/lib64 -Llib -l$(LIBNAME) -lrt -lm -L/user-environment/linux-sles15-neoverse_v2/gcc-13.2.0/cuda-12.4.0-wezsc3dqlnvhhvjyvi5xrkxe2t2ofwgo/lib64 -lmpi -ldl -L/usr/lib64 -L/opt/cray/xpmem/default/lib64 -lxpmem

.PHONY: all clean
all: lib/lib$(LIBNAME).a $(TESTSBIN) $(INITBENCHMARKSBIN) obj/gpu/cuda_core.o

lib/lib$(LIBNAME).a: $(OBJECTS) obj/gpu/cuda_core.o
	ar -r lib/lib$(LIBNAME).a $(OBJ)/core/*.o $(OBJ)/mpi/*.o $(OBJ)/fortran/*.o $(OBJ)/noopt/*.o $(OBJ)/gpu/*.o

#lib/lib$(LIBNAME).so: $(OBJECTS) obj/gpu/cuda_core.o
#	$(NVCC) -shared $(LIBS) $(OBJ)/core/*.o $(OBJ)/mpi/*.o $(OBJ)/fortran/*.o $(OBJ)/noopt/*.o $(OBJ)/gpu/*.o -o lib/lib$(LIBNAME).so

DEPFLAGS = -MMD -MT $(OBJ)/$*.o -MP -MF $(DEPDIR)/$*.d
DEPENDENCIES = $(subst src,$(DEPDIR),$(SOURCES:.c=.d))

COMPILE.c = $(CC) $(DEPFLAGS) $(CFLAGS) $(TARGET_ARCH) -c

latency_bandwidth.tmp: minclude.sh latency_bandwidth/ext_mpi_bm.txt
	./minclude.sh latency_bandwidth/ext_mpi_bm.txt > latency_bandwidth.tmp

hip/%.c: src/%.c
	hipify-perl src/$*.c > hip/$*.c

.deps/%.d: hip/%.c latency_bandwidth.tmp
	$(COMPILE.c) $< -E > /dev/null

bin_tests/%.x: tests/%.c
	hipify-perl tests/$*.c > hip/tests/$*.c
	$(NVCC) $(CFLAGS) $(TARGET_ARCH) $(OUTPUT_OPTION) hip/tests/$*.c $(LIBS)

bin/%.x: src/initial_benchmark/%.c
	$(NVCC) $(CFLAGS) $(TARGET_ARCH) $(OUTPUT_OPTION) src/initial_benchmark/$*.c $(LIBS)

DEPFILES := $(patsubst %.c,%.d,$(subst src,$(DEPDIR),$(SOURCES)))
$(DEPFILES):

include $(DEPFILES)

obj/gpu/cuda_core.o: src/gpu/cuda_core.cu
	hipify-perl src/gpu/cuda_core.cu > hip/gpu/cuda_core.hip
	$(NVCC) -c $(NVCFLAGS) $(TARGET_ARCH) $(OUTPUT_OPTION) hip/gpu/cuda_core.hip

obj/noopt/%.o: .deps/noopt/%.d
	$(CC) -c $(CFLAGS) -O0 $(TARGET_ARCH) $(OUTPUT_OPTION) src/noopt/$*.c

obj/%.o: .deps/%.d
	$(CC) -c $(CFLAGS) $(TARGET_ARCH) $(OUTPUT_OPTION) hip/$*.c

clean:
	rm $(OBJ)/core/*.o $(OBJ)/mpi/*.o $(OBJ)/gpu/*.o $(OBJ)/fortran/*.o $(OBJ)/noopt/*.o $(OBJ)/initial_benchmark/*.o $(OBJ)/gpu/*.o hip/core*.hip hip/mpi*.hip hip/gpu*.hip hip/fortran/*.hip hip/noopt/*.hip hip/initial_benchmark/*.hip lib/lib$(LIBNAME).a $(BIN)/* bin_tests/* latency_bandwidth.tmp
